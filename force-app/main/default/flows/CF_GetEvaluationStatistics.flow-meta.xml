    <description>Retrieves recent call evaluation statistics for the specified agent, including total evaluations and average overall score within a defined time period. This autolaunched flow is used by the Coachforce Employee Agent to provide agents with a concise summary of their recent performance and coaching trends.</description>
    <environments>Default</environments>
    <formulas>
        <name>frmAverageScore</name>
        <dataType>Number</dataType>
        <expression>IF({!varEvalCount} &gt; 0, {!varScoreSum} / {!varEvalCount}, 0)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>frmStartDate</name>
        <dataType>Date</dataType>
        <expression>TODAY() - {!daysBack}</expression>
    </formulas>
    <formulas>
        <name>frmStartDateText</name>
        <dataType>String</dataType>
        <expression>TEXT({!frmStartDate})</expression>
    </formulas>
    <interviewLabel>Coachforce - Get Basic Evaluation Statistics {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Coachforce - Get Evaluation Statistics</label>
    <loops>
        <name>Loop_Evals</name>
        <label>Loop Evals</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_Evaluations</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assign_Vars</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Assign_Output</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
