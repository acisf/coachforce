<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CF_Percent_Score__c</fullName>
    <description>Final normalized score: earned points divided by applicable points.</description>
    <formula>IF(
  CF_Applicable_Points__c &gt; 0,
  CF_Score__c / CF_Applicable_Points__c,
  0
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Percent Score</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
