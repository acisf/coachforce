<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CF_Display_Outcome__c</fullName>
    <description>Returns values like Passed, Failed, or N/A for reporting and screen display.</description>
    <externalId>false</externalId>
    <formula>IF(
  NOT(CF_Applicable__c),
  &quot;N/A&quot;,
  IF(CF_Passed__c, &quot;Passed&quot;, &quot;Failed&quot;)
)</formula>
    <label>Display Outcome</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
